# Flow Evolution for Mind - 环境变量模板

# 【Tier 1】内置平台（填一个即可，优先使用硅基流动）
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# OPENROUTER_API_KEY=sk-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ANTHROPIC_API_KEY=sk-your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# GEMINI_API_KEY=your-key-here
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1

# 【Tier 2】自定义 OpenAI 兼容平台
# CUSTOM_BASE_URL=https://api.xxx.com/v1
# CUSTOM_API_KEY=sk-your-key-here
# CUSTOM_MODEL=xxx

# 项目路径（可选，默认自动发现）
# FLOW_EVOLUTION_DIR=/Users/yourname/flow-evolution-for-mind

# OpenClaw 数据路径（非默认时设置）
# OPENCLAW_DATA_DIR=/path/to/openclaw/data
