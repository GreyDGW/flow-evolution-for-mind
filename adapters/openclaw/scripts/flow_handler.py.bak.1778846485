#!/usr/bin/env python3
"""
Flow Skill 主入口 —— 增量导入 + 日期计算 + 查库 + 生成报告

路径解耦设计：
1. 优先从环境变量 FLOW_EVOLUTION_DIR 读取核心层路径
2. 如果没设置，自动搜索常见安装路径
3. 还是没找到，报错并提示用户设置环境变量

接收 OpenClaw LLM 提取的参数：
  --intent-type mirror/tool_recommend/unblock
  --time-keyword today/yesterday/week/date/last_N
  --date-value 2026-04-19（当 time-keyword=date 时）
  --limit 5（当 time-keyword=last_N 时）
  --update-style (flag) Style Scanner: 分析最近5轮并更新调音
  --agent techboss (str) Agent ID

输出：Markdown 报告到 stdout
"""

import sys
import os
import argparse
from datetime import datetime, timedelta

# ============================================
# 1. 路径解耦：发现核心层
# ============================================
def find_core_dir():
    """三层查找：环境变量 → 自动发现 → 报错"""
    
    # 第一层：环境变量
    core_dir = os.getenv("FLOW_EVOLUTION_DIR")
    if core_dir and os.path.exists(os.path.join(core_dir, "data", "flow_ecosystem.db")):
        return core_dir
    
    # 第二层：自动发现常见路径
    candidates = [
        os.path.expanduser("~/flow-evolution-for-mind"),   # 标准安装路径（GitHub clone）
        os.path.expanduser("~/.flow-evolution-for-mind"), # 隐藏目录
        os.path.expanduser("~/Desktop/skill相关文档/openclaw_flow_plugin"),  # 开发路径
    ]
    for c in candidates:
        if os.path.exists(os.path.join(c, "data", "flow_ecosystem.db")):
            return c
    
    # 第三层：报错
    print("❌ 找不到 Flow Evolution 核心层", file=sys.stderr)
    print("请确认以下之一：", file=sys.stderr)
    print("  1. 核心层安装在标准路径 ~/flow-evolution-for-mind/", file=sys.stderr)
    print("  2. 设置环境变量：export FLOW_EVOLUTION_DIR=/path/to/core", file=sys.stderr)
    sys.exit(1)

CORE_DIR = find_core_dir()
sys.path.insert(0, CORE_DIR)
os.chdir(CORE_DIR)

from importer import incremental
from plugin.report_assembler import ReportAssembler


def parse_time_range(time_keyword: str, date_value: str = None, limit: int = None):
    """把 LLM 提取的时间关键词转成具体的时间戳字符串"""
    now = datetime.now()
    today = now.replace(hour=0, minute=0, second=0, microsecond=0)
    
    if time_keyword == "week":
        weekday = today.weekday()
        start = today - timedelta(days=weekday)
        end = now
    elif time_keyword == "yesterday":
        start = today - timedelta(days=1)
        end = today
    elif time_keyword == "today":
        start = today
        end = now
    elif time_keyword == "date" and date_value:
        start = datetime.strptime(date_value, "%Y-%m-%d")
        end = start + timedelta(days=1)
    elif time_keyword.startswith("last_") and limit:
        start = today - timedelta(days=7)
        end = now
    else:
        start = today
        end = now
    
    return start.strftime("%Y-%m-%d %H:%M:%S"), end.strftime("%Y-%m-%d %H:%M:%S")


def update_style(agent_id: str):
    """
    Style Scanner —— 每5轮后台触发。
    查最近5轮 + Portrait基线 + 调LLM → 更新 kv_store。
    """
    import sqlite3
    import json
    from plugin.llm_client import LLMClientFactory
    
    db_path = os.path.join(CORE_DIR, "data", "flow_ecosystem.db")
    conn = sqlite3.connect(db_path)
    c = conn.cursor()
    
    # 1. 最近 5 轮用户消息
    c.execute("""
        SELECT content_text FROM sessions 
        WHERE role = 'user' AND session_id LIKE ? 
        ORDER BY timestamp DESC LIMIT 5
    """, (f'{agent_id}%',))
    last5 = [row[0] for row in c.fetchall()]
    last5.reverse()
    
    # 2. 最近 5 个 Session 的 Portrait 分布（主基线）
    c.execute("""
        SELECT portrait_label, COUNT(*) as cnt 
        FROM session_analyses 
        WHERE session_id LIKE ? 
        GROUP BY portrait_label 
        ORDER BY created_at DESC 
        LIMIT 5
    """, (f'{agent_id}%',))
    portrait_dist = c.fetchall()
    
    # 3. 当前 Style
    c.execute("""
        SELECT value FROM kv_store 
        WHERE agent_id = ? AND key = 'current_style'
    """, (agent_id,))
    row = c.fetchone()
    current_style = json.loads(row[0]) if row else {"pace": "steady", "depth": "analytical", "tone": "neutral"}
    
    conn.close()
    
    # 4. 组装 Watchdog Prompt
    prompt = f"""你是一个状态监测器。

用户最近 5 个 Session 的画像分布（主要基线）：
{portrait_dist}

用户当前状态：{current_style['pace']} / {current_style['depth']} / {current_style['tone']}

阅读最近 5 轮对话，判断用户是否发生了显著的状态破裂或突变。
注意：用户近期整体处于上述画像模式，偶尔的急躁或困惑是常态，不要误判为突变。
只有当行为明显偏离基线时，才输出新的 pace/depth/tone。

最近 5 轮对话：
{' | '.join(last5[:3])}

输出 JSON：
{{
  "pace": "urgent|steady|explore|hold|anchor",
  "depth": "surface|analytical|philosophical",
  "tone": "supportive|challenging|neutral|warm",
  "confidence": 0.0-1.0,
  "reason": "一句话解释"
}}

规则：
- confidence < 0.8 时保持上一次的style不变，输出 "KEEP"
- 不要编造，只基于提供的对话判断
"""
    
    # 5. 调 LLM
    client = LLMClientFactory.create()
    response = client.chat(prompt, max_tokens=400)
    
    if not response:
        print("⚠️ Style Scanner LLM 调用失败", file=sys.stderr)
        return
    
    # 6. 解析
    try:
        import json
        # 清理可能的 Markdown 格式
        clean = response.strip()
        if clean.startswith("```json"):
            clean = clean[7:]
        if clean.endswith("```"):
            clean = clean[:-3]
        clean = clean.strip()
        
        result = json.loads(clean)
        if result.get("confidence", 0) < 0.8 or result.get("pace") == "KEEP":
            print("ℹ️ Style Scanner: KEEP", file=sys.stderr)
            return
        
        # 7. 更新 kv_store
        new_style = {
            "pace": result["pace"],
            "depth": result["depth"],
            "tone": result["tone"]
        }
        conn = sqlite3.connect(db_path)
        c = conn.cursor()
        c.execute("""
            INSERT OR REPLACE INTO kv_store (agent_id, key, value, updated_at) 
            VALUES (?, 'current_style', ?, datetime('now'))
        """, (agent_id, json.dumps(new_style)))
        conn.commit()
        conn.close()
        print(f"✅ Style 更新: {new_style}", file=sys.stderr)
        
    except Exception as e:
        print(f"⚠️ Style Scanner 解析失败: {e}\n原始响应: {response[:200]}", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(description="Flow 认知镜像 Skill")
    parser.add_argument("--intent-type", default="mirror")
    parser.add_argument("--time-keyword", default="today")
    parser.add_argument("--date-value", default=None)
    parser.add_argument("--limit", type=int, default=None)
    parser.add_argument("--update-style", action="store_true", help="Style Scanner: 分析最近5轮并更新调音")
    parser.add_argument("--agent", type=str, default="techboss", help="Agent ID")
    args = parser.parse_args()
    
    # Style Scanner 分支
    if args.update_style:
        update_style(args.agent)
        sys.exit(0)
    
    # 增量导入
    print(f"🔄 正在同步数据（核心层: {CORE_DIR}）...", file=sys.stderr)
    try:
        imported = incremental.run_once(
            jsonl_dir="~/.openclaw/agents",
            db_path="data/flow_ecosystem.db"
        )
        print(f"✅ 同步完成，新增 {imported} 条消息", file=sys.stderr)
    except Exception as e:
        print(f"⚠️ 同步数据时出错: {e}", file=sys.stderr)
    
    # 日期计算
    start_str, end_str = parse_time_range(args.time_keyword, args.date_value, args.limit)
    print(f"📅 时间范围: {start_str} ~ {end_str}", file=sys.stderr)
    
    # 生成报告
    print("📊 正在生成报告...", file=sys.stderr)
    try:
        assembler = ReportAssembler(db="data/flow_ecosystem.db")
        report = assembler.generate_flow_report(
            session_limit=50,
            trend_limit=30,
            start=start_str,
            end=end_str
        )
    except Exception as e:
        print(f"❌ 生成报告失败: {e}", file=sys.stderr)
        report = f"生成报告时出错: {e}"
    
    print(report)


if __name__ == "__main__":
    main()
