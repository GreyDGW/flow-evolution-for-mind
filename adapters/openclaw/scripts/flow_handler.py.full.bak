#!/usr/bin/env python3
"""
Flow Skill 主入口 —— 增量导入 + 日期计算 + 查库 + 生成报告

路径解耦设计：
1. 优先从环境变量 FLOW_EVOLUTION_DIR 读取核心层路径
2. 如果没设置，自动搜索常见安装路径
3. 还是没找到，报错并提示用户设置环境变量

接收 OpenClaw LLM 提取的参数：
  --intent-type mirror/tool_recommend/unblock
  --time-keyword today/yesterday/week/date/last_N
  --date-value 2026-04-19（当 time-keyword=date 时）
  --limit 5（当 time-keyword=last_N 时）
  --update-style (flag) Style Scanner: 分析最近5轮并更新调音
  --agent techboss (str) Agent ID

输出：Markdown 报告到 stdout
"""

import sys
import os
import argparse
from datetime import datetime, timedelta

# ============================================
# 1. 路径解耦：发现核心层
# ============================================
def find_core_dir():
    """三层查找：环境变量 → 自动发现 → 报错"""
    
    # 第一层：环境变量
    core_dir = os.getenv("FLOW_EVOLUTION_DIR")
    if core_dir and os.path.exists(os.path.join(core_dir, "data", "flow_ecosystem.db")):
        return core_dir
    
    # 第二层：自动发现常见路径
    candidates = [
        os.path.expanduser("~/flow-evolution-for-mind"),   # 标准安装路径（GitHub clone）
        os.path.expanduser("~/.flow-evolution-for-mind"), # 隐藏目录
        os.path.expanduser("~/Desktop/skill相关文档/openclaw_flow_plugin"),  # 开发路径
    ]
    for c in candidates:
        if os.path.exists(os.path.join(c, "data", "flow_ecosystem.db")):
            return c
    
    # 第三层：报错
    print("❌ 找不到 Flow Evolution 核心层", file=sys.stderr)
    print("请确认以下之一：", file=sys.stderr)
    print("  1. 核心层安装在标准路径 ~/flow-evolution-for-mind/", file=sys.stderr)
    print("  2. 设置环境变量：export FLOW_EVOLUTION_DIR=/path/to/core", file=sys.stderr)
    sys.exit(1)

CORE_DIR = find_core_dir()
sys.path.insert(0, CORE_DIR)
os.chdir(CORE_DIR)

from importer import incremental
from plugin.deep_report_final import DeepReportFinal


def parse_time_range(time_keyword: str, date_value: str = None, limit: int = None):
    """把 LLM 提取的时间关键词转成具体的时间戳字符串"""
    now = datetime.now()
    today = now.replace(hour=0, minute=0, second=0, microsecond=0)
    
    # V7.8-9-4-3 FIX: date_value 优先级高于 time_keyword（支持 --date-value 覆盖）
    if date_value:
        try:
            start = datetime.strptime(date_value, "%Y-%m-%d")
            end = start + timedelta(days=1)
            return start.strftime("%Y-%m-%d %H:%M:%S"), end.strftime("%Y-%m-%d %H:%M:%S")
        except ValueError:
            pass  # 格式错误时 fallback 到 time_keyword
    
    if time_keyword == "week":
        weekday = today.weekday()
        start = today - timedelta(days=weekday)
        end = now
    elif time_keyword == "yesterday":
        start = today - timedelta(days=1)
        end = today
    elif time_keyword == "today":
        start = today
        end = now
    elif time_keyword.startswith("last_") and limit:
        start = today - timedelta(days=7)
        end = now
    else:
        start = today
        end = now
    
    return start.strftime("%Y-%m-%d %H:%M:%S"), end.strftime("%Y-%m-%d %H:%M:%S")


def update_style(agent_id: str, turn_count: int = 0):
    """Style Scanner -- V7.8-9 per-turn trigger."""
    import sqlite3, json
    from plugin.llm_client import LLMClientFactory
    from datetime import datetime, timedelta

    db_path = os.path.join(CORE_DIR, "data", "flow_ecosystem.db")
    conn = sqlite3.connect(db_path)
    c = conn.cursor()

    # 1. Recent 5 user messages (exclude system noise)
    c.execute("SELECT content_text FROM sessions WHERE role IN ('user', 'assistant') AND (is_auto_push = 0 OR is_auto_push IS NULL) AND session_id LIKE ? ORDER BY timestamp DESC LIMIT 5", (f'{agent_id}%',))
    last5 = [r[0] for r in c.fetchall()][::-1]

    # 2. Current Style (4D, backward compatible)
    c.execute("SELECT value FROM kv_store WHERE agent_id=? AND key='current_style'", (agent_id,))
    row = c.fetchone()
    current_style = json.loads(row[0]) if row else {"pace":"explore","depth":"surface","tone":"neutral","friction":"direct"}
    if "friction" not in current_style: current_style["friction"] = "direct"

    # V7.8-9-2: 修复 agent_id 查询（兼容历史 NULL 数据）
    # 最近 5 次 Session Portrait
    c.execute("""
        SELECT portrait_label,style_pace,style_depth,style_tone,style_friction,rule_insight
        FROM session_analyses
        WHERE (agent_id = ? OR agent_id IS NULL OR agent_id = '')
        ORDER BY created_at DESC LIMIT 5
    """, (agent_id,))
    recent = c.fetchall()
    # 今日分布
    today = datetime.now().strftime("%Y-%m-%d")
    c.execute("""
        SELECT portrait_label,COUNT(*) FROM session_analyses
        WHERE (agent_id = ? OR agent_id IS NULL OR agent_id = '') AND created_at LIKE ?
        GROUP BY portrait_label
    """, (agent_id,f'{today}%'))
    today_dist = c.fetchall()
    # 本周分布
    week_ago = (datetime.now()-timedelta(days=7)).strftime("%Y-%m-%d")
    c.execute("""
        SELECT portrait_label,COUNT(*) FROM session_analyses
        WHERE (agent_id = ? OR agent_id IS NULL OR agent_id = '') AND created_at>=?
        GROUP BY portrait_label
    """, (agent_id,week_ago))
    week_dist = c.fetchall()
    conn.close()

    # Friction legal domain mapping
    # V7.8-9-3: 删除 friction_map，friction 由 Scanner 独立判断，Portrait 不再锁定合法域

    # 4. Cold start: first 3 turns free judgment
    if turn_count <= 3:
        baseline = None
    else:
        if recent:
            label,pace,depth,tone,friction,insight = recent[0]
            # V7.8-9-3: friction 不再锁定，Scanner 自由选择
            baseline = {
                "label":label,
                "4d_base":{"pace":pace or "explore","depth":depth or "surface","tone":tone or "neutral","friction":friction or "direct"},
                "friction_allowed":["direct","socratic","dynamic"],"rule_insight":insight or ""
            }
        else:
            baseline = None

    # 5. Assemble Scanner Prompt
    bt = f"[Baseline] Main: {baseline['label']} ({baseline['4d_base']['pace']}/{baseline['4d_base']['depth']}/{baseline['4d_base']['tone']}/{baseline['4d_base']['friction']}) | Friction allowed: {','.join(baseline['friction_allowed'])} | Insight: {baseline['rule_insight']}" if baseline else "[Cold start] No baseline for first 3 turns."

    prompt = f"You are state sensor. {bt} | Current: {current_style['pace']}/{current_style['depth']}/{current_style['tone']}/{current_style['friction']} | Turn: #{turn_count} | Recent: {'|'.join(last5[:3])} | Analyze: 1.Energy shift? 2.Deviation from 4D baseline (0.0-1.0)? 3.Choose friction within legal domain. 4.BLEND_RATIO (0.0-1.0). | Output: ACTION:KEEP|UPDATE STYLE:pace=xxx,depth=xxx,tone=xxx,friction=xxx DEVIATION:0.0-1.0 BLEND_RATIO:0.0-1.0 REASON:10chars | Rules: DEVIATION<0.4->KEEP; 0.4-0.7->WATCH; >=0.7->UPDATE;- friction freely chosen by Scanner based on current turn; cold start free judgment."

    # 6. Call LLM
    client = LLMClientFactory.create()
    resp = client.chat(prompt, max_tokens=400)
    if not resp: print("LLM failed",file=sys.stderr); return

    # 7. Parse + local filtering
    try:
        res = {}
        for line in resp.strip().split('\n'):
            if ':' in line: k,v=line.split(':',1); res[k.strip().lower()]=v.strip()
        action=res.get('action','KEEP').upper()
        dev=float(res.get('deviation','0.0'))
        blend=float(res.get('blend_ratio','0.7'))

        # V7.8-9: BLEND_RATIO 简化决策（方案 B）
        # blend<0.5 时即使 dev>=0.7 也观望，避免小波动导致风格跳变
        if action=='KEEP' or dev<0.4: print(f"KEEP(dev={dev})",file=sys.stderr); return
        if dev<0.7 or blend<0.5: print(f"WATCH(dev={dev},blend={blend})",file=sys.stderr); return

        style_line=res.get('style','')
        new_style={}
        for p in style_line.split(','):
            if '=' in p: k,v=p.split('=',1); new_style[k.strip()]=v.strip()
        for k in ['pace','depth','tone','friction']: new_style.setdefault(k,current_style[k])

    # V7.8-9-3: 删除冲突拦截，friction 由 Scanner 独立判断，Portrait 不再锁定合法域

        # 8. Update kv_store
        conn=sqlite3.connect(db_path); c=conn.cursor()
        # V7.8-9-2: 确保 portrait 写入 kv_store（兼容旧数据）
        if 'portrait' not in new_style:
            if recent:
                new_style['portrait'] = recent[0][0]
            else:
                new_style['portrait'] = '平稳推进'
        c.execute("INSERT OR REPLACE INTO kv_store(agent_id,key,value,updated_at)VALUES(?,'current_style',?,datetime('now'))",(agent_id,json.dumps(new_style)))
        conn.commit(); conn.close()
        print(f"Updated: {new_style} (dev={dev},blend={blend})",file=sys.stderr)
    except Exception as e:
        print(f"Parse failed: {e}\n Response: {resp[:200]}",file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(description="Flow 认知镜像 Skill")
    parser.add_argument("--intent-type", default="mirror")
    parser.add_argument("--time-keyword", default="today")
    parser.add_argument("--date-value", default=None)
    parser.add_argument("--limit", type=int, default=None)
    parser.add_argument("--update-style", action="store_true", help="Style Scanner: 分析最近5轮并更新调音")
    parser.add_argument("--agent", type=str, default="techboss", help="Agent ID")
    parser.add_argument("--turn-count", type=int, default=0, help="Current turn count")
    args = parser.parse_args()
    
    # V7.8-9-4-3 FIX: 确保 session_analyses 表存在（首次安装无数据时）
    import sqlite3
    conn = sqlite3.connect("data/flow_ecosystem.db")
    c = conn.cursor()
    try:
        c.execute("SELECT 1 FROM session_analyses LIMIT 1")
    except sqlite3.OperationalError:
        c.execute("""
            CREATE TABLE session_analyses (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                session_id TEXT,
                goal_alignment TEXT,
                closure_index TEXT,
                flow_depth TEXT,
                cognition_growth TEXT,
                goal_evidence TEXT,
                closure_evidence TEXT,
                flow_evidence TEXT,
                cognition_evidence TEXT,
                portrait_label TEXT,
                portrait_description TEXT,
                portrait_suggestion TEXT,
                portrait_rule_insight TEXT,
                style_pace TEXT,
                style_depth TEXT,
                style_tone TEXT,
                style_friction TEXT,
                agent_id TEXT,
                llm_model TEXT,
                llm_latency_ms INTEGER,
                prompt_version TEXT DEFAULT 'v1',
                rule_insight TEXT DEFAULT '',
                created_at TEXT DEFAULT CURRENT_TIMESTAMP,
                UNIQUE(session_id, created_at)
            )
        """)
    conn.commit()
    conn.close()
    
    # Style Scanner 分支
    if args.update_style:
        update_style(args.agent, args.turn_count)
        sys.exit(0)
    
    # V7.8-9-4-3 FIX: 隔离 sys.argv，防止参数污染下游（batch_session_cutter 等）
    # 原因：run_once() 内部可能调用 cutter，cutter 的 .venv 切换会继承 sys.argv
    _saved_argv = sys.argv[:]
    sys.argv = [sys.argv[0]]  # 只保留脚本名
    try:
        # 增量导入
        print(f"🔄 正在同步数据（核心层: {CORE_DIR}）...", file=sys.stderr)
        imported = incremental.run_once(
            db_path="data/flow_ecosystem.db"
        )
        print(f"✅ 同步完成，新增 {imported} 条消息", file=sys.stderr)

        # === 积压检测：如果有大量历史未分析数据，自动补齐 ===
        try:
            from batch_analyze_with_save import find_unanalyzed_sessions, analyze_date
            from datetime import datetime, timedelta

            unanalyzed_all = find_unanalyzed_sessions(
                db_path="data/flow_ecosystem.db",
                since_minutes=525600  # 1年
            )
            if len(unanalyzed_all) > 20:
                print(f"[Flow] ⚠️ 检测到 {len(unanalyzed_all)} 个历史 session 未分析，正在自动补齐最近7天...", file=sys.stderr)
                for i in range(7):
                    date_str = (datetime.now() - timedelta(days=i)).strftime("%Y-%m-%d")
                    try:
                        analyze_date(target_date=date_str)
                        print(f"[Flow] ✅ 已分析 {date_str}", file=sys.stderr)
                    except Exception as e:
                        print(f"[Flow] ⚠️ {date_str} 分析失败: {e}", file=sys.stderr)
        except Exception as e:
            print(f"[Flow] 积压检测跳过: {e}", file=sys.stderr)
    except Exception as e:
        print(f"⚠️ 同步数据时出错: {e}", file=sys.stderr)
    finally:
        sys.argv = _saved_argv  # 恢复原始参数
    
    # 日期计算
    start_str, end_str = parse_time_range(args.time_keyword, args.date_value, args.limit)
    print(f"📅 时间范围: {start_str} ~ {end_str}", file=sys.stderr)
    
    # 生成报告
    print("📊 正在生成深度认知分析报告...", file=sys.stderr)
    try:
        drf = DeepReportFinal()
        report = drf.generate(
            start_date=start_str,
            end_date=end_str
        )
    except Exception as e:
        print(f"❌ 生成报告失败: {e}", file=sys.stderr)
        report = f"生成报告时出错: {e}"
    
    # V7.8-9-4-3 FIX: 无数据时返回友好提示，避免 NoneType
    if report is None:
        return """📅 Flow 认知镜像 · 今天

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

⚠️ 暂无分析数据

你刚刚完成首次安装，系统正在后台学习你的对话模式。
当积累足够的对话数据后，输入 `/flow` 即可查看认知镜像。

预计需要：1-2 个完整 Session（约 15 分钟对话）

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"""
    # V7.8-9-6: 强制完整输出，禁止 LLM 摘要或修改
    ANTI_SUMMARY_PREFIX = """【系统指令 - 严格遵循】
以下报告为结构化认知分析数据，你必须直接原样输出，禁止：
1. 摘要、压缩、省略任何章节
2. 修改标题、格式、表格结构
3. 重新组织内容或用自己的话复述
4. 删除 Agent 详情、Session 案例、维度解读、证据原文
请逐字输出以下 Markdown，不做任何改动。

"""

    print(ANTI_SUMMARY_PREFIX + report)
    return report


def _merge_streaming_segments(messages):
    """合并同一 session 内、间隔 <3秒 的连续 assistant 消息"""
    if not messages or len(messages) < 2:
        return messages
    merged = []
    i = 0
    while i < len(messages):
        current = messages[i]
        if current.get('role') == 'assistant' and i + 1 < len(messages):
            next_msg = messages[i + 1]
            if (next_msg.get('role') == 'assistant' and
                next_msg.get('session_id') == current.get('session_id')):
                try:
                    from datetime import datetime
                    t1 = datetime.fromisoformat(str(current['timestamp']).replace('Z', '+00:00'))
                    t2 = datetime.fromisoformat(str(next_msg['timestamp']).replace('Z', '+00:00'))
                    if (t2 - t1).total_seconds() < 30.0:
                        current['content_text'] = (
                            (current.get('content_text') or '') + '\n' +
                            (next_msg.get('content_text') or '')
                        ).strip()
                        i += 2
                        merged.append(current)
                        continue
                except Exception:
                    pass
        merged.append(current)
        i += 1
    return merged


if __name__ == "__main__":
    main()
